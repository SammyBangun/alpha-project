{
  "name": "project-alpha",
  "version": "0.1.0",
  "private": true,
  "description": "Project Alpha — Personal Operating System for discipline and self-mastery",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
