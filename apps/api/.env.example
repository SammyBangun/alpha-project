# Project Alpha API — environment (ARCHITECTURE §10)
# Copy to .env and fill real secrets. The Docker db (docker compose up -d db) listens on 5433.
DATABASE_URL="postgresql://alpha:alpha@localhost:5433/project_alpha"

JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="30d"

PORT="4000"
CORS_ORIGIN="http://localhost:3000"
